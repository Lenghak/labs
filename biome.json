{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": false,
    "root": "."
  },
  "files": {
    "ignoreUnknown": true,
    "ignore": ["**/node_modules/**", "**/target/**"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "ignore": ["**/node_modules/**", "**/target/**"]
  },
  "organizeImports": {
    "enabled": true,
    "ignore": ["**/node_modules/**", "**/target/**"]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    },
    "ignore": ["**/node_modules/**", "**/target/**"]
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  }
}
